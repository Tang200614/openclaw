# Browser data
browser/openclaw/user-data/*
!browser/openclaw/user-data/.gitkeep

# Logs
logs/**
*.log
**/node_modules/

# Backups
*.bak*
openclaw.json.bak*
workspace-dev/

# IDE/Editor
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.temp
*.reset.*

# Sessions/Auth local state
agents/main/sessions/sessions.json
identity/device-auth.json
devices/paired.json
update-check.json

# Runtime session artifacts
agents/main/sessions/*.jsonl
agents/main/sessions/boot-*.jsonl
agents/main/sessions/*.jsonl.lock

# Runtime memory snapshots
workspace/memory/*.md

# SQLite runtime journals
*.sqlite-wal
*.sqlite-shm
